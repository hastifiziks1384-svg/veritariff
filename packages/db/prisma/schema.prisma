// Veritariff data model (§4 of the spec).
//
// SQLite for dev; PostgreSQL-ready: no SQLite-only or Postgres-only column
// types are used. Enum-like fields are String (validated as unions in
// @veritariff/shared); JSON-shaped fields are String columns holding
// serialized JSON (parse via shared toJson/fromJson). On the Postgres
// switchover these upgrade to native enums/jsonb without data-model changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Shipment {
  id                 String    @id @default(cuid())
  reference          String?
  shipperName        String?
  consigneeName      String?
  originCountry      String? // ISO 3166-1 alpha-2
  destinationCountry String?
  lane               String? // e.g. "EU->UK"
  shipmentDate       DateTime?
  createdAt          DateTime  @default(now())

  documents          Document[]
  classifications    Classification[]
  originRuleContexts OriginRuleContext[]
  flags              Flag[]
  evidenceBundles    EvidenceBundle[]
  auditEvents        AuditEvent[]
}

model Document {
  id               String   @id @default(cuid())
  shipmentId       String
  shipment         Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  type             String // DocumentType union
  format           String // pdf | txt | eml | csv | ...
  source           String // upload | email | connector
  rawFileUrl       String
  originalFilename String?
  uploadedAt       DateTime @default(now())

  extractedFields ExtractedField[]
}

model ExtractedField {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  name       String // CanonicalField union (or a document-specific extra)
  value      String?
  unit       String?
  confidence Float? // 0–1; null only when status = missing
  status     String // extracted | low_confidence | missing
  createdAt  DateTime @default(now())
}

model Classification {
  id             String   @id @default(cuid())
  shipmentId     String
  shipment       Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  hsCode         String
  declaredHsCode String?
  confidence     Float
  // Ordered reasoning steps (JSON array): which Section/Chapter notes and
  // GIRs were applied, in order. Never generated by an LLM.
  reasoningChain String
  citations      String // JSON array of Citation — required, never empty
  status         String // ClassificationStatus union
  // Version stamp of the reference data the determination was made against.
  rulesDataVersion String?
  createdAt        DateTime @default(now())
}

model OriginRuleContext {
  id           String   @id @default(cuid())
  shipmentId   String
  shipment     Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  hsHeading    String
  agreement    String   @default("TCA")
  ruleText     String
  ruleType     String // CTH | MaxNOM | wholly_obtained | combination
  citedArticle String
  // Plain-English explanation of the rule. Verification/explanation only —
  // must never be phrased as, or stored as, a qualification claim.
  plainEnglish     String?
  isIllustrative   Boolean  @default(true)
  rulesDataVersion String
  createdAt        DateTime @default(now())
}

model Flag {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  field       String
  severity    String // info | warn | block
  // Which engine raised the flag: extraction | mismatch | classification
  source      String   @default("system")
  // JSON array of ConflictingValue — every value tied to its source document.
  conflictingValues String
  explanation       String
  citation          String? // JSON Citation, when a legal source backs the flag

  // Deterministic recommendation (never for hs_code flags). Only present when
  // the engine has a defensible basis; the basis is always shown to the user.
  recommendedValue     String?
  recommendedValueUnit String?
  recommendationBasis  String? // e.g. "packing list is the authoritative source for gross weight"
  recommendationStatus String  @default("none") // none | proposed | accepted | rejected

  resolution   String    @default("open") // open | resolved | ignored | escalated
  resolvedBy   String?
  resolvedNote String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
}

model EvidenceBundle {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  generatedAt DateTime @default(now())
  // Full JSON snapshot: record + flags + classification reasoning + origin
  // rule + citations + timestamps + rules-data version.
  contents         String
  rulesDataVersion String?
}

// Append-only audit trail. Flag resolutions, recommendation accept/reject,
// ingestion events, exports — all land here.
model AuditEvent {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  at         DateTime @default(now())
  actor      String // user identifier or "system"
  action     String // e.g. "flag.recommendation.accepted", "shipment.seeded"
  detail     String // JSON payload
}
