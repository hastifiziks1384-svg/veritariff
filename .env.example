# SQLite database file, resolved relative to packages/db/prisma/schema.prisma.
# Swapping to PostgreSQL in production is a datasource change in schema.prisma
# plus a postgres:// URL here.
DATABASE_URL="file:./dev.db"

# Optional. Enables live document field extraction via the hosted LLM.
# Without it, the FixtureExtractionService is used (demo/tests fully work).
# The deterministic engine (packages/engine) never uses this — see docs/DECISIONS.md.
ANTHROPIC_API_KEY=

# Demo password gate (apps/web/middleware.ts). Leave empty for local dev.
# Set both on the hosting platform to lock the deployed site behind a
# browser login popup — share these credentials with demo viewers only.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
